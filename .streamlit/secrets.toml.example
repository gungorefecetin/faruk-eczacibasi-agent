# Streamlit Community Cloud secrets — TEMPLATE (placeholders only, never real keys).
#
# Deploy: App → Settings → Secrets, paste the sections you use, replace placeholders.
# Local dev: copy this to `.streamlit/secrets.toml` (gitignored) OR keep using .env
#            and the config.*.json files — both still work unchanged.
#
# How the app consumes these:
#   - Flat keys (OPENAI_API_KEY, ...) are mirrored into os.environ by Streamlit,
#     so core.config._has_key(...) picks them up with no code change.
#   - The [tables] below are flattened into os.environ by app._bridge_secrets_to_env()
#     as {TABLE}_{FIELD} (uppercased), which core.config reads as a fallback when the
#     matching config.*.json file is absent (i.e. on Cloud).

# ── Demo login gate ──
APP_PASSWORD = "REPLACE_WITH_DEMO_PASSWORD"

# ── Env-var providers (OpenAI, Anthropic, Gemini) ──
# Gemini reuses the OpenAI-compatible provider; it only needs its key here.
OPENAI_API_KEY    = "REPLACE_WITH_OPENAI_KEY"
ANTHROPIC_API_KEY = "REPLACE_WITH_ANTHROPIC_KEY"
GEMINI_API_KEY    = "REPLACE_WITH_GEMINI_KEY"

# ── Azure OpenAI judge (local equivalent: config.json) ──
# -> AZURE_JUDGE_API_KEY / _API_VERSION / _AZURE_ENDPOINT / _DEPLOYMENT_NAME
[azure_judge]
api_key         = "REPLACE_WITH_AZURE_OPENAI_KEY"
api_version     = "2024-08-01-preview"
azure_endpoint  = "https://REPLACE-RESOURCE.openai.azure.com/"
deployment_name = "REPLACE_WITH_GPT_DEPLOYMENT_NAME"

# ── Azure Foundry: Grok (local equivalent: config.grok.json) ──
# -> FOUNDRY_GROK_ENDPOINT / _API_KEY_ENV / _MODEL
# NOTE: `api_key_env` holds a RAW key despite the historical name.
[foundry_grok]
endpoint    = "https://REPLACE-RESOURCE.services.ai.azure.com/api/projects/REPLACE-PROJECT"
api_key_env = "REPLACE_WITH_AZURE_FOUNDRY_KEY"
model       = "REPLACE_WITH_GROK_DEPLOYMENT_NAME"

# ── Azure Foundry: Kimi (local equivalent: config.kimi.json) ──
# -> FOUNDRY_KIMI_ENDPOINT / _API_KEY_ENV / _MODEL
[foundry_kimi]
endpoint    = "https://REPLACE-RESOURCE.services.ai.azure.com/api/projects/REPLACE-PROJECT"
api_key_env = "REPLACE_WITH_AZURE_FOUNDRY_KEY"
model       = "REPLACE_WITH_KIMI_DEPLOYMENT_NAME"
